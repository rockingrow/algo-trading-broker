# ─────────────────────────────────────────────────────────────────
# Webhook Server
# ─────────────────────────────────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Optional HMAC secret — set the same value in TradingView alert header
# X-Signature: <sha256-hex-of-body>
# Leave blank to disable validation.
WEBHOOK_SECRET=changeme_super_secret

# ─────────────────────────────────────────────────────────────────
# ZeroMQ Publisher  (broker → subscribers)
# ─────────────────────────────────────────────────────────────────
ZMQ_BROKER_HOST=*           # bind to all interfaces
ZMQ_PUB_PORT=5555
ZMQ_TOPIC=SIGNAL            # topic prefix for published signals

# ─────────────────────────────────────────────────────────────────
# ZeroMQ PULL Listener  (subscribers → broker)
# Subscribers PUSH trade event reports here for DB logging.
# ─────────────────────────────────────────────────────────────────
ZMQ_PULL_HOST=*             # bind to all interfaces
ZMQ_PULL_PORT=5556

# ─────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=algo_broker
POSTGRES_USER=algo
POSTGRES_PASSWORD=changeme

# ─────────────────────────────────────────────────────────────────
# Trade defaults
# ─────────────────────────────────────────────────────────────────
DEFAULT_VOLUME=0.1
DEFAULT_SL_PIPS=50
DEFAULT_TP_PIPS=100
INSTRUMENT_MAGIC=20240101

# Broker instrument map: universal_name=broker_name,...
INSTRUMENT_MAP=EURUSD=EURUSD,XAUUSD=XAUUSD,BTCUSD=BTCUSD

# ─────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
