BROKER_PUBLIC_URL=server_ip_or_domain
BROKER_API_PREFIX=secret_prefix_no_one_should_know

# ─────────────────────────────────────────────────────────────────
# Webhook Server
# ─────────────────────────────────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=80

# Callback APIs
BROKER_API_KEY=api_key

# Optional HMAC secret — set the same value in TradingView alert header
# X-Signature: <sha256-hex-of-body>
# Leave blank to disable validation.
WEBHOOK_SECRET=5a7a92a5-7a26-42c7-a981-fd20c0040acf

# ─────────────────────────────────────────────────────────────────
# NATS
# ─────────────────────────────────────────────────────────────────
NATS_HOST=localhost
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_TOKEN=changeme

# ─────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=algo_trading_broker
POSTGRES_USER=algo_trading
POSTGRES_PASSWORD=algotrading_broker_db_password

# ─────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────
# API Docs (Swagger UI /docs, ReDoc /redoc, schema /openapi.json)
# Set to false in production to hide the interactive docs entirely.
# ─────────────────────────────────────────────────────────────────
DOCS_ENABLED=false

# ─────────────────────────────────────────────────────────────────
# Telegram
# TELEGRAM_CHAT_ID is for individual chat, manage service, NATS broker notifications, etc.
# TELEGRAM_CHAT_CHANNEL_ID is for broadcasting channel as group includes Broker, Workers and administrators.
# ─────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_CHANNEL_ID="-"
# Forward log records at ERROR level or above to the management chat (TELEGRAM_CHAT_ID).
TELEGRAM_LOG_ERRORS_ENABLED=false
