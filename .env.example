BROKER_PUBLIC_URL=server_ip_or_domain
BROKER_API_PREFIX=secret_prefix_no_one_should_know

# ─────────────────────────────────────────────────────────────────
# Webhook Server
# ─────────────────────────────────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=80

# Seconds an idle keep-alive connection is held open. Must exceed the gap between
# TradingView alerts: TradingView reuses pooled connections, and uvicorn's 5s
# default closes them first — the alert then fails with
# "server closed the connection unexpectedly".
WEBHOOK_KEEPALIVE_TIMEOUT=120

# Callback APIs
BROKER_API_KEY=api_key

# Optional HMAC secret — set the same value in TradingView alert header
# X-Signature: <sha256-hex-of-body>
# Leave blank to disable validation.
WEBHOOK_SECRET=5a7a92a5-7a26-42c7-a981-fd20c0040acf

# ─────────────────────────────────────────────────────────────────
# NATS (JetStream must be enabled on the server: `nats-server -js -sd <dir>`
# — the bundled docker-compose.yml already does this)
# ─────────────────────────────────────────────────────────────────
NATS_HOST=localhost
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_TOKEN=changeme

# ─────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=algo_trading_broker
POSTGRES_USER=algo_trading
POSTGRES_PASSWORD=algotrading_broker_db_password

# ─────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────
# API Docs (Swagger UI /docs, ReDoc /redoc, schema /openapi.json)
# Set to false in production to hide the interactive docs entirely.
# ─────────────────────────────────────────────────────────────────
DOCS_ENABLED=false

# ─────────────────────────────────────────────────────────────────
# Telegram
# TELEGRAM_CHAT_ID is for individual chat, manage service, NATS broker notifications, etc.
# TELEGRAM_CHAT_CHANNEL_ID is for broadcasting channel as group includes Broker, Workers and administrators.
# ─────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_CHANNEL_ID="-"
# Forward log records at ERROR level or above via a dedicated bot/chat.
# When TELEGRAM_LOG_BOT_TOKEN / TELEGRAM_LOG_CHAT_ID are empty, the hook
# falls back to TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID.
TELEGRAM_LOG_ERRORS_ENABLED=false
TELEGRAM_LOG_BOT_TOKEN=
TELEGRAM_LOG_CHAT_ID=

# ─────────────────────────────────────────────────────────────────
# Telegram Bot (interactive bot service — folder ./bot)
# Uses its own BotFather bot/token, separate from TELEGRAM_BOT_TOKEN above
# (which is the broker's send-only notification/alert bot). Create a second
# bot via @BotFather and put its token in BOT_TELEGRAM_TOKEN. BOT_BROKER_BASE_URL
# is overridden to http://broker:<port> inside docker-compose. If
# BROKER_API_PREFIX is set, the bot prepends it. Also uses BROKER_API_KEY above.
#
# TELEGRAM_ADMIN_IDS: comma-separated Telegram user IDs that get the admin menu
# and admin commands (/accounts, /atrades, /aflat, /rotate, /settings). Find
# your numeric ID via @userinfobot. Leave blank = no admins. Example: 123,456
# ─────────────────────────────────────────────────────────────────
BOT_TELEGRAM_TOKEN=
TELEGRAM_ADMIN_IDS=
BOT_BROKER_BASE_URL=http://localhost:8080
BOT_LOG_LEVEL=INFO
BOT_REQUEST_TIMEOUT=10.0
BOT_VIEW_TRADES_PER_PAGE=50
