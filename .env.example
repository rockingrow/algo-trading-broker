# ─────────────────────────────────────────────────────────────────
# Webhook Server
# ─────────────────────────────────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Optional HMAC secret — set the same value in TradingView alert header
# X-Signature: <sha256-hex-of-body>
# Leave blank to disable validation.
WEBHOOK_SECRET=5a7a92a5-7a26-42c7-a981-fd20c0040acf

# ─────────────────────────────────────────────────────────────────
# ZeroMQ Publisher  (broker → subscribers)
# ─────────────────────────────────────────────────────────────────
ZMQ_BROKER_HOST=*           # bind to all interfaces
ZMQ_PUB_PORT=5555

# ─────────────────────────────────────────────────────────────────
# ZeroMQ CURVE Authentication
# Generate a keypair:  python scripts/generate_curve_keypair.py
# ─────────────────────────────────────────────────────────────────
ZMQ_CURVE_ENABLED=true
# Paste the output of generate_curve_keypair.py below:
ZMQ_CURVE_SERVER_PUBLIC_KEY="<40-char Z85 public key>"
ZMQ_CURVE_SERVER_SECRET_KEY="<40-char Z85 secret key>"

# ─────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=algo_trading_broker
POSTGRES_USER=algo_trading
POSTGRES_PASSWORD=algotrading_broker_db_password

# Broker instrument map: universal_name=broker_name,...
INSTRUMENT_MAP=EURUSD=EURUSD,XAUUSD=XAUUSD,BTCUSD=BTCUSD

# ─────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=